# ============================================================
# Central Zap - Backend - Exemplo de variáveis de ambiente
# Copie este arquivo para ".env" e preencha os valores.
# ============================================================

# Porta em que o backend Express irá rodar
PORT=3001

# Segredo usado para assinar os tokens JWT (altere para algo seguro!)
JWT_SECRET=centralzap_super_secret_change_me

# Tempo de expiração do token (ex: 7d, 24h, 15m)
JWT_EXPIRES_IN=7d

# URL do frontend (usada pelo CORS para permitir requisições locais)
FRONTEND_URL=http://localhost:5173

# Caminho do banco SQLite (relative path)
DATABASE_URL="file:./dev.db"

# Pasta onde as sessões do Baileys são salvas (uma subpasta por conta)
SESSIONS_DIR=./sessions

# Habilita logs detalhados (true/false)
DEBUG=false
